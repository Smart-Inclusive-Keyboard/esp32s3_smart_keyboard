menu "SMART KEYBOARD"

#
# Hardware board selection. Each board entry "select"s capability
# symbols that other components key off of. To add a new board,
# duplicate one of the entries below, add a matching pin/init file
# under components/board/src/board_<name>.c, and reference it from
# components/board/CMakeLists.txt.
#

choice SK_BOARD
    prompt "Target board"
    default SK_BOARD_WAVESHARE_ESP32S3_TOUCH_LCD_35B
    help
        Selects the hardware board the firmware is built for.
        The board choice determines pin assignments, display
        controller, presence of PSRAM / speaker / battery, and
        which capability flags are exposed to the rest of the
        firmware.

config SK_BOARD_WAVESHARE_ESP32S3_TOUCH_LCD_35B
    bool "Waveshare ESP32-S3-Touch-LCD-3.5B"
    depends on IDF_TARGET_ESP32S3
    select BOARD_HAS_PSRAM
    select BOARD_HAS_DISPLAY
    select BOARD_HAS_DISPLAY_AXS15231B
    select BOARD_HAS_SPEAKER
    select BOARD_HAS_CODEC_ES8311
    select BOARD_HAS_TOUCH
    help
        Waveshare 3.5" 320x480 IPS panel with AXS15231B QSPI
        controller on ESP32-S3 with 16 MB flash + 8 MB octal
        PSRAM. Includes an on-board I2S speaker (ES8311 codec
        on MCLK=44, BCLK=13, LRCK=15, DOUT=16) which is wired
        up automatically for the narrator. The external gamepad
        SPI bus is hard-wired to SCLK=9, MOSI=10, MISO=11 on
        SPI3 (no chip-select pin). I2C gamepad transport is not
        supported on this board out of the box -- edit
        board_waveshare_esp32s3_touch_lcd_35b.c to point at
        free pins if you need it.

config SK_BOARD_GENERIC_ESP32S3
    bool "Generic ESP32-S3 (no display configured)"
    depends on IDF_TARGET_ESP32S3
    help
        Placeholder for a custom ESP32-S3 board. Pin definitions
        live in components/board/src/board_generic_s3.c -- edit
        that file to match your wiring.

config SK_BOARD_GENERIC_ESP32
    bool "Generic ESP32 (no display configured)"
    depends on IDF_TARGET_ESP32
    help
        Placeholder for a custom classic-ESP32 board.

endchoice

#
# Capability flags. Each board "select"s the subset it has; the rest
# of the firmware reads them via #ifdef CONFIG_BOARD_HAS_xxx.
#

config BOARD_HAS_PSRAM
    bool
    default n

config BOARD_HAS_DISPLAY
    bool
    default n

config BOARD_HAS_DISPLAY_AXS15231B
    bool
    default n

config BOARD_HAS_SPEAKER
    bool
    default n

config BOARD_HAS_CODEC_ES8311
    bool
    default n

config BOARD_HAS_TOUCH
    bool
    default n

config BOARD_HAS_BATTERY
    bool
    default n

#
# External gamepad. Pick the bus the gamepad is wired to and
# configure its pins / clock. The polling cadence and axis
# dead-zone are common to all transports.
#

menu "Gamepad"

choice SK_GAMEPAD_TRANSPORT
    prompt "Gamepad transport"
    default SK_GAMEPAD_TRANSPORT_SPI
    help
        Selects the bus used to talk to the external gamepad.
        The firmware is always the bus master; the gamepad is
        always the slave / peripheral.

config SK_GAMEPAD_TRANSPORT_I2C
    bool "I2C (device is master)"

config SK_GAMEPAD_TRANSPORT_SPI
    bool "SPI (device is host, gamepad is slave)"

endchoice

config SK_GAMEPAD_POLL_MS
    int "Poll period (ms)"
    default 16
    range 5 100
    help
        Interval between gamepad HID reads. ~60 Hz (16 ms) is a
        good default for responsive on-screen navigation.

config SK_GAMEPAD_AXIS_DEADZONE
    int "Axis dead-zone (signed, 0..127)"
    default 40
    range 0 127

menu "I2C gamepad"
    depends on SK_GAMEPAD_TRANSPORT_I2C

config SK_GAMEPAD_I2C_PORT
    int "I2C port number"
    range 0 1
    default 0

config SK_GAMEPAD_I2C_SDA_GPIO
    int "I2C SDA GPIO"
    default 11
    help
        I2C SDA pin used to talk to the external gamepad
        controller.

config SK_GAMEPAD_I2C_SCL_GPIO
    int "I2C SCL GPIO"
    default 10

config SK_GAMEPAD_I2C_FREQ_HZ
    int "I2C clock (Hz)"
    default 100000
    range 50000 400000

config SK_GAMEPAD_I2C_ADDR
    hex "Gamepad 7-bit I2C address"
    default 0x52
    range 0x08 0x77
    help
        7-bit slave address of the I2C gamepad. The default 0x52
        matches a Wii-Nunchuk-style controller; change to suit
        your controller.

endmenu  # I2C gamepad

menu "SPI gamepad"
    depends on SK_GAMEPAD_TRANSPORT_SPI

config SK_GAMEPAD_SPI_HOST
    int "SPI host (peripheral index)"
    default 2
    range 1 3
    help
        SPI host the device drives as a master. On the ESP32-S3
        SPI2 (HSPI, host 2) and SPI3 (host 3) are general-purpose;
        SPI1 is reserved for flash on most targets. The display
        component on the Waveshare board owns SPI2, so prefer
        host 3 there.

config SK_GAMEPAD_SPI_SCLK_GPIO
    int "SPI SCLK GPIO"
    default 11
    help
        Serial clock pin driven by the device (master) toward the
        gamepad (slave).

config SK_GAMEPAD_SPI_MOSI_GPIO
    int "SPI MOSI GPIO"
    default 10
    help
        Master-out / slave-in. Used to send a dummy / command
        byte; the parser ignores the response if the gamepad
        is read-only.

config SK_GAMEPAD_SPI_MISO_GPIO
    int "SPI MISO GPIO"
    default 9
    help
        Master-in / slave-out. The 4-byte gamepad report is
        clocked back to the device on this line.

config SK_GAMEPAD_SPI_CS_GPIO
    int "SPI CS (chip-select) GPIO"
    default 17
    help
        Chip-select pin asserted by the device (master) for the
        duration of each transaction.

config SK_GAMEPAD_SPI_FREQ_HZ
    int "SPI clock (Hz)"
    default 1000000
    range 100000 10000000
    help
        SPI clock frequency. 1 MHz is a conservative default that
        works over loose jumpers; raise it once the wiring is
        stable.

config SK_GAMEPAD_SPI_MODE
    int "SPI mode (0..3)"
    default 0
    range 0 3
    help
        SPI mode (CPOL / CPHA). Match the slave gamepad's
        expected mode.

endmenu  # SPI gamepad

endmenu  # Gamepad

#
# HID transport selection. The device acts as a HID peripheral over
# either Bluetooth Low Energy or USB. Each option is only offered
# when the selected ESP32 model actually has the matching radio /
# controller (SOC_BLE_SUPPORTED / SOC_USB_OTG_SUPPORTED come from
# the IDF SoC capability headers).
#

choice SK_HID_TRANSPORT
    prompt "HID interface"
    default SK_HID_TRANSPORT_USB
    help
        Selects the transport the device uses to act as a HID
        peripheral. Only interfaces supported by the chosen
        ESP32 model are selectable: BLE requires a Bluetooth LE
        radio, USB requires on-chip USB OTG (e.g. ESP32-S2 /
        ESP32-S3).

config SK_HID_TRANSPORT_BLE
    bool "BLE HID (Bluetooth LE keyboard)"
    depends on SOC_BLE_SUPPORTED
    select BT_ENABLED
    help
        Use NimBLE to advertise a composite HID-over-GATT
        keyboard + mouse. Auto-enables the Bluetooth controller.

        The NimBLE host (CONFIG_BT_NIMBLE_ENABLED) must also be
        selected as the Bluetooth host stack. It is set by
        sdkconfig.defaults for fresh builds, but cannot be
        force-selected from here because BT_NIMBLE_ENABLED is a
        member of ESP-IDF's `choice BT_HOST` (Kconfig disallows
        `select` on choice members). If you carried over an
        sdkconfig that has Bluedroid as the host, switch it in
        menuconfig:
          Component config -> Bluetooth -> Host -> NimBLE - BLE only
        or delete sdkconfig and re-run `idf.py set-target ...`.
        components/ble_hid/CMakeLists.txt asserts this and emits
        a clear error otherwise.

config SK_HID_TRANSPORT_USB
    bool "USB HID (USB keyboard)"
    depends on SOC_USB_OTG_SUPPORTED
    help
        Use TinyUSB to expose a composite HID keyboard + mouse
        on the on-chip USB OTG controller. The Bluetooth stack
        can be disabled in 'Component config -> Bluetooth' to
        reclaim ~60 KB flash / ~30 KB RAM.

endchoice

#
# BLE HID device identity.
#

menu "BLE HID"
    depends on SK_HID_TRANSPORT_BLE

config SK_BLE_DEVICE_NAME
    string "Advertised device name"
    default "SmartKeyboard"

config SK_BLE_MANUFACTURER
    string "Manufacturer string"
    default "clackups"

config SK_BLE_BOND_ON_PAIR
    bool "Persist bonds to NVS"
    default y

endmenu  # BLE HID

#
# USB HID device identity. Shown by the host's Device Manager /
# `lsusb` output.
#

menu "USB HID"
    depends on SK_HID_TRANSPORT_USB

config SK_USB_MANUFACTURER
    string "USB iManufacturer string"
    default "clackups"

config SK_USB_PRODUCT
    string "USB iProduct string"
    default "SmartKeyboard"

config SK_USB_SERIAL
    string "USB iSerial string"
    default "000001"
    help
        Used as the serial-number string descriptor. Hosts use
        this to distinguish multiple identical devices; pick
        something unique if you flash more than one board.

endmenu  # USB HID

#
# Keyboard layout.
#

choice SK_LAYOUT_DEFAULT
    prompt "Default keyboard layout"
    default SK_LAYOUT_US
    help
        Compile-time default layout. The runtime layout can be
        switched via the on-screen menu and is persisted in NVS.

config SK_LAYOUT_US
    bool "US English (default)"

config SK_LAYOUT_DE
    bool "German (DE) - layout stub"

config SK_LAYOUT_FR
    bool "French (FR) - layout stub"

config SK_LAYOUT_UA
    bool "Ukrainian (UA) - layout stub"

endchoice

#
# Color theme.
#

choice SK_THEME_DEFAULT
    prompt "Default color theme"
    default SK_THEME_GREEN_ON_BLACK
    help
        Compile-time default theme. May be overridden at runtime
        via the on-screen menu (persisted in NVS).

config SK_THEME_GREEN_ON_BLACK
    bool "Green on black (default)"

config SK_THEME_DARKGREEN_ON_BLACK
    bool "Dark green on black"

config SK_THEME_WHITE_ON_BLACK
    bool "White on black"

config SK_THEME_BLACK_ON_WHITE
    bool "Black on white"

config SK_THEME_DEFAULT_PALETTE
    bool "Plain default palette"

endchoice

#
# Audio / narrator. The whole menu is hidden unless the board has
# PSRAM and a speaker, because narration requires both.
#

menu "Audio / Narrator"
    depends on BOARD_HAS_PSRAM && BOARD_HAS_SPEAKER

config NARRATOR_ENABLE
    bool "Speak letter names as the user navigates"
    default y

config AUDIO_I2S_PORT
    int "I2S port number"
    default 0
    range 0 1
    help
        Sound output is always over I2S (no internal-DAC / PWM
        fallback). Set the port number that matches your board.

config AUDIO_I2S_BCLK_GPIO
    int "I2S BCLK (bit clock) GPIO"
    default 5

config AUDIO_I2S_LRCK_GPIO
    int "I2S LRCK (word select) GPIO"
    default 6

config AUDIO_I2S_DOUT_GPIO
    int "I2S DOUT (serial data) GPIO"
    default 7

config AUDIO_VOLUME
    int "Default narrator volume (%)"
    default 70
    range 0 100

endmenu  # Audio / Narrator

endmenu  # SMART KEYBOARD
